# Polymarket Wallet
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_FUNDER_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Polymarket Market (laisser vide = mode demo)
POLYMARKET_TOKEN_ID=

# CORS (origines autorisees, separer par virgule)
CORS_ORIGINS=http://localhost:1818,http://127.0.0.1:1818,https://trading.youpiare.fr

# Risk Settings
MAX_POSITION_SIZE=10
MAX_DAILY_LOSS=50
MAX_OPEN_POSITIONS=3

# Bot Settings
LOG_LEVEL=INFO
DRY_RUN=true

# ===== ALERTES =====
# Au moins un canal (Email ou Telegram) doit etre configure

# Email (Gmail) — recommande
# 1. Aller sur https://myaccount.google.com/apppasswords
# 2. Creer un mot de passe d'application
# 3. Copier le code de 16 caracteres ci-dessous
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Telegram (optionnel, en complement)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Seuils d'alerte (en $)
ALERT_LOSS_THRESHOLD=5
ALERT_GAIN_THRESHOLD=10
ALERT_DAILY_LOSS_THRESHOLD=20
ALERT_DAILY_GAIN_THRESHOLD=50
