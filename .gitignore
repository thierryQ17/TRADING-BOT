# =============================================================================
# .gitignore - Projet Polymarket Trading Bot
# =============================================================================

# -----------------------------------------------------------------------------
# Fichiers d'environnement et configuration locale
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
build/

# -----------------------------------------------------------------------------
# Donnees locales (generees)
# -----------------------------------------------------------------------------
data/*.csv
data/*.db
data/*.sqlite

# -----------------------------------------------------------------------------
# Logs et fichiers temporaires
# -----------------------------------------------------------------------------
logs/
*.log
tmp/
temp/

# -----------------------------------------------------------------------------
# IDE et editeurs
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Fichiers systeme
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
